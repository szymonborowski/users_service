# Example: users deployment with automatic migrations and seeds
apiVersion: apps/v1
kind: Deployment
metadata:
  name: users-app
  namespace: portfolio
  labels:
    app.kubernetes.io/name: users
    app.kubernetes.io/part-of: portfolio
spec:
  replicas: 1
  selector:
    matchLabels:
      app.kubernetes.io/name: users
  template:
    metadata:
      labels:
        app.kubernetes.io/name: users
    spec:
      terminationGracePeriodSeconds: 30
      initContainers:
        # 1. Copy public files (existing)
        - name: copy-public
          image: ghcr.io/szymonborowski/microservices-users:v0.0.3
          command: ["sh", "-c", "cp -r /var/www/html/public/. /shared/public/"]
          securityContext:
            runAsUser: 0
          volumeMounts:
            - name: public-files
              mountPath: /shared/public

        # 2. Run migrations and seeds (NEW)
        - name: migrate-and-seed
          image: ghcr.io/szymonborowski/microservices-users:v0.0.3
          command:
            - sh
            - -c
            - |
              echo "Running migrations..."
              php artisan migrate --force

              echo "Running seeds..."
              php artisan db:seed --force

              echo "Database initialization complete!"
          envFrom:
            - configMapRef:
                name: users-config
            - secretRef:
                name: users-secret
          resources:
            limits:
              cpu: 200m
              memory: 256Mi
            requests:
              cpu: 100m
              memory: 128Mi

      containers:
        - name: php-fpm
          image: ghcr.io/szymonborowski/microservices-users:v0.0.3
          ports:
            - containerPort: 9000
              protocol: TCP
          envFrom:
            - configMapRef:
                name: users-config
            - secretRef:
                name: users-secret
          livenessProbe:
            tcpSocket:
              port: 9000
            initialDelaySeconds: 10
            periodSeconds: 10
          readinessProbe:
            tcpSocket:
              port: 9000
            initialDelaySeconds: 5
            periodSeconds: 5
          resources:
            requests:
              cpu: 100m
              memory: 128Mi
            limits:
              cpu: 500m
              memory: 512Mi

        - name: nginx
          image: nginx:1.27-alpine
          ports:
            - containerPort: 80
              protocol: TCP
          lifecycle:
            preStop:
              exec:
                command: ["/bin/sh", "-c", "sleep 5"]
          volumeMounts:
            - name: public-files
              mountPath: /var/www/html/public
            - name: nginx-config
              mountPath: /etc/nginx/conf.d
          readinessProbe:
            httpGet:
              path: /ready
              port: 80
            initialDelaySeconds: 5
            periodSeconds: 5
          livenessProbe:
            httpGet:
              path: /health
              port: 80
            initialDelaySeconds: 15
            periodSeconds: 20
          resources:
            requests:
              cpu: 50m
              memory: 64Mi
            limits:
              cpu: 200m
              memory: 128Mi

      volumes:
        - name: public-files
          emptyDir: {}
        - name: nginx-config
          configMap:
            name: users-nginx-config
